# Neon Postgres connection string — the SAME database is used for local dev and
# production, so there is never a local->prod data export. Get it from:
#   https://neon.tech -> your project -> Connect -> copy the connection string.
#
# Recommended: create a dedicated "dev" branch in Neon and use ITS connection
# string here, so local work never touches production data:
#   Neon dashboard -> Branches -> New branch ("dev") -> Connect -> copy string.
#
# Use the *pooled* connection string (host contains "-pooler") for the serverless driver.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Shared secret that protects POST /api/ingest in production. Leave UNSET locally
# (the endpoint is then open for convenience). In production set the same value in
# Vercel env vars AND as the GitHub Actions secret INGEST_TOKEN.
# INGEST_TOKEN=change-me-to-a-long-random-string

# Optional overrides (defaults live in code).
# NESO_API_BASE=https://api.carbonintensity.org.uk

# Octopus Agile tariff used for the carbon x price scheduler (free, no key needed).
# AGILE_REGION is the DNO region letter (A-P); default 'C' = London. AGILE_PRODUCT
# is the Agile product code; bump it if Octopus retires the current one.
# AGILE_REGION=C
# AGILE_PRODUCT=AGILE-24-04-03
